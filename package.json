{
  "name": "hysa-code",
  "version": "0.4.0",
  "description": "Open-source AI coding assistant CLI - multiple providers including free cloud and local models",
  "type": "module",
  "license": "MIT",
  "author": "HYSA Code",
  "keywords": [
    "ai",
    "coding-assistant",
    "cli",
    "open-source",
    "ollama",
    "deepseek",
    "groq",
    "openrouter",
    "claude",
    "gpt",
    "gemini",
    "code-editor",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hysa/hysa-code.git"
  },
  "bugs": {
    "url": "https://github.com/hysa/hysa-code/issues"
  },
  "homepage": "https://github.com/hysa/hysa-code#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "dist/",
    "web/dist/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "bin": {
    "hysa": "./bin/hysa.js"
  },
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc",
    "build:web": "cd web && npm install && npm run build",
    "build:bundle": "node ./node_modules/esbuild/bin/esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs --external:esbuild",
    "build:exe": "npm run build:web && npm run build:bundle && node ./node_modules/@yao-pkg/pkg/lib-es5/bin.js -c package.json dist/bundle.cjs --targets node22-win-x64 --output hysa.exe && node -e \"let d=require('fs').readFileSync('hysa.exe'),p=d.readUInt32LE(0x3C);d.writeUInt16LE(2,p+0x5C);require('fs').writeFileSync('hysa.exe',d);console.log('Patched to GUI subsystem')\" && node -e \"require('fs').copyFileSync('hysa.exe','web/dist/download.exe')\"",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:web": "cd web && npx vite",
    "check": "node ./node_modules/typescript/bin/tsc --noEmit",
    "prepublishOnly": "npm run build && npm run build:web && npm run check",
    "version": "node -e \"const fs=require('fs');const p=JSON.parse(fs.readFileSync('package.json'));p.version=process.env.npm_package_version;fs.writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n')\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.31.0",
    "@google/generative-ai": "^0.21.0",
    "@inquirer/prompts": "^7.0.0",
    "commander": "^12.0.0",
    "diff": "^7.0.0",
    "express": "^5.2.1",
    "ignore": "^6.0.0",
    "openai": "^4.70.0",
    "picocolors": "^1.1.0"
  },
  "pkg": {
    "assets": [
      "web/dist/index.html",
      "web/dist/**/*.css",
      "web/dist/**/*.js"
    ]
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@types/diff": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@yao-pkg/pkg": "^6.19.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
