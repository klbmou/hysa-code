{
  "name": "hysa-code",
  "version": "0.2.0",
  "description": "Open-source AI coding assistant CLI - multiple providers including free cloud and local models",
  "type": "module",
  "license": "MIT",
  "author": "HYSA Code",
  "keywords": [
    "ai",
    "coding-assistant",
    "cli",
    "open-source",
    "ollama",
    "deepseek",
    "groq",
    "openrouter",
    "claude",
    "gpt",
    "gemini",
    "code-editor",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hysa/hysa-code.git"
  },
  "bugs": {
    "url": "https://github.com/hysa/hysa-code/issues"
  },
  "homepage": "https://github.com/hysa/hysa-code#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "web/dist/",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "hysa": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:web": "cd web && npm install && npx vite build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:web": "cd web && npx vite",
    "check": "tsc --noEmit",
    "prepare": "npm run build && npm run build:web",
    "prepack": "npm run build && npm run build:web",
    "prepublishOnly": "npm run build && npm run build:web && npm run check",
    "version": "node -e \"const fs=require('fs');const p=JSON.parse(fs.readFileSync('package.json'));p.version=process.env.npm_package_version;fs.writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n')\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.31.0",
    "@google/generative-ai": "^0.21.0",
    "@inquirer/prompts": "^7.0.0",
    "commander": "^12.0.0",
    "diff": "^7.0.0",
    "express": "^5.2.1",
    "ignore": "^6.0.0",
    "openai": "^4.70.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
